# PayPal
# IMPORTANTE: cole aqui seus valores. Não compartilhe o Secret publicamente.
PAYPAL_MODE=live   # sandbox ou live
PAYPAL_CLIENT_ID=COLE_SEU_CLIENT_ID
PAYPAL_CLIENT_SECRET=COLE_SEU_SECRET
PAYPAL_WEBHOOK_ID=COLE_O_WEBHOOK_ID

# GitHub (para editar o products.json no seu repo)
GITHUB_TOKEN=COLE_SEU_GITHUB_PAT
GITHUB_REPO=STAVARENG0/vintage
GITHUB_BRANCH=main
GITHUB_PRODUCTS_PATH=products.json

# Estoque
REMOVE_ON_SALE=true   # true => remove o produto quando stock chega a 0 (peça única)

# Server
PORT=8080
